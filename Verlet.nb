Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Verlet", "[", 
    RowBox[{"a_", ",", "x0_", ",", "v0_", ",", "dt_", ",", "Ns_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "xout", ",", "xnext", ",", "xcur", ",", "xprev", ",", "t", ",", 
       "index"}], "}"}], ",", 
     RowBox[{
      RowBox[{"xout", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0.0", ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", "Ns"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"xcur", "=", "x0"}], ";", "\[IndentingNewLine]", 
      RowBox[{"xprev", "=", 
       RowBox[{"x0", "-", 
        RowBox[{"dt", " ", "v0"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "2"}], ")"}], " ", 
         RowBox[{"a", "[", 
          RowBox[{"x0", ",", "0.0"}], "]"}], " ", 
         RowBox[{"dt", "^", "2"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"t", "=", "0.0"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"xout", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "=", 
       RowBox[{"{", 
        RowBox[{"t", ",", "x0"}], "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"index", "=", "2"}], ",", 
        RowBox[{"index", "\[LessEqual]", "Ns"}], ",", 
        RowBox[{"index", "=", 
         RowBox[{"index", "+", "1"}]}], ",", 
        RowBox[{
         RowBox[{"xnext", "=", 
          RowBox[{
           RowBox[{"2.0", " ", "xcur"}], "-", "xprev", "+", 
           RowBox[{
            RowBox[{"dt", "^", "2"}], " ", 
            RowBox[{"a", "[", 
             RowBox[{"xcur", ",", "t"}], "]"}]}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"t", "=", 
          RowBox[{"t", "+", "dt"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"xout", "[", 
           RowBox[{"[", "index", "]"}], "]"}], "=", 
          RowBox[{"{", 
           RowBox[{"t", ",", "xnext"}], "}"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"xprev", "=", "xcur"}], ";", "\[IndentingNewLine]", 
         RowBox[{"xcur", "=", "xnext"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "xout", "]"}], ";"}]}], "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
